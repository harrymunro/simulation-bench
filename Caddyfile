{
    auto_https off
    admin off
}

:80 {
    root * /srv
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; script-src 'self'; object-src 'none'; base-uri 'self'"
        -Server
    }

    # Resolve directory URLs (e.g. /methodology/scoring/) to their index.html
    # before falling back to the leaderboard for true 404s.
    try_files {path} {path}index.html {path}/index.html /index.html
    file_server
}
